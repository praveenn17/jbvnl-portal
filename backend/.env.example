# ── JBVNL Portal — Backend Environment Variables ────────────────────────────
# Copy this file to .env and fill in your real values.
# NEVER commit your real .env file to version control.
#
# Usage:
#   cp .env.example .env
#   then edit .env with your credentials

# ── Server ────────────────────────────────────────────────────────────────────
NODE_ENV=development          # 'development' or 'production'
PORT=5000                     # Port the Express server listens on

# ── Database ──────────────────────────────────────────────────────────────────
# Required — the script will exit with a clear error if this is missing.
MONGO_URI=                    # e.g. mongodb+srv://<user>:<pass>@<host>/<db>

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=                   # Long random string — keep secret!

# ── Admin Seed Credentials ────────────────────────────────────────────────────
# Used by:  npm run seed:admin
# If not set, the script falls back to the default values shown below
# and prints a warning. Always set these explicitly in production.
ADMIN_EMAIL=admin@jbvnl.in
ADMIN_PASSWORD=               # Must meet strong-password rules (see authController)
ADMIN_NAME=JBVNL Admin

# ── Email / SMTP (for OTP verification) ──────────────────────────────────────
# In development (NODE_ENV=development) the OTP is also printed to the console,
# so you can leave these blank while testing locally.
#
# For Gmail:
#   1. Enable 2-Step Verification at https://myaccount.google.com/security
#   2. Generate an App Password for "Mail"
#   3. Use that 16-char code as SMTP_PASS (NOT your real Gmail password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=                    # e.g. yourname@gmail.com
SMTP_PASS=                    # 16-char Gmail App Password
SMTP_FROM=JBVNL Portal <noreply@jbvnl.in>
