{
    "rewrites": [
        { "source": "/api/(.*)", "destination": "/_/backend/api/$1" }
    ],
    "experimentalServices": {
        "frontend": {
            "entrypoint": "frontend",
            "routePrefix": "/",
            "framework": "vite"
        },
        "backend": {
            "entrypoint": "backend",
            "routePrefix": "/_/backend"
        }
    }
}
